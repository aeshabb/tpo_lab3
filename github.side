  "suites": [
    {
      "id": "suite-all-use-cases",
      "name": "All Use Cases",
      "persistSession": false,
      "parallel": false,
      "timeout": 300,
      "tests": [
        "test-uc01-search",
        "test-uc02-topics",
        "test-uc03-trending-java",
        "test-uc04-invalid-login",
        "test-uc05-repository-tabs",
